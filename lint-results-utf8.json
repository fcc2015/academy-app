v className=\"bg-red-400 h-full transition-all\" style={{ width: `${(absentCount / Math.max(total, 1)) * 100}%` }}></div>\r\n                        )}\r\n                    </div>\r\n                </div>\r\n                <div className=\"flex gap-6 mt-3 text-xs font-bold\">\r\n                    <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-emerald-500\"></span> Present</span>\r\n                    <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-amber-400\"></span> Late</span>\r\n                    <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-red-400\"></span> Absent</span>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Records */}\r\n            <div className=\"bg-white rounded-2xl border border-slate-200 premium-shadow overflow-hidden\">\r\n                <div className=\"px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between\">\r\n                    <h3 className=\"font-extrabold text-slate-800 text-lg\">Attendance History</h3>\r\n                    <span className=\"text-xs font-black text-slate-400 bg-slate-100 px-3 py-1.5 rounded-lg\">{total} Records</span>\r\n                </div>\r\n                {attendance.length === 0 ? (\r\n                    <div className=\"p-12 text-center\">\r\n                        <CalendarCheck className=\"mx-auto text-slate-200 mb-4\" size={48} />\r\n                        <h4 className=\"font-bold text-slate-800 mb-2\">No Records Yet</h4>\r\n                        <p className=\"text-sm text-slate-500\">Attendance records will appear here once the coach starts tracking.</p>\r\n                    </div>\r\n                ) : (\r\n                    <div className=\"divide-y divide-slate-100\">\r\n                        {attendance.map((record, i) => {\r\n                            const config = statusConfig[record.status] || statusConfig.present;\r\n                            const Icon = config.icon;\r\n                            return (\r\n                                <div key={i} className=\"p-5 flex items-center justify-between hover:bg-slate-50/50 transition-colors\">\r\n                                    <div className=\"flex items-center gap-4\">\r\n                                        <div className=\"text-sm font-bold text-slate-800 w-28\">\r\n                                            {record.date ? new Date(record.date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) : 'N/A'}\r\n                                        </div>\r\n                                    </div>\r\n                                    <span className={`flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-black uppercase tracking-wider ${config.bg} ${config.color} border ${config.border}`}>\r\n                                        <Icon size={14} /> {config.label}\r\n                                    </span>\r\n                                </div>\r\n                            );\r\n                        })}\r\n                    </div>\r\n                )}\r\n            </div>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default ParentAttendance;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\src\\pages\\parent\\ParentChat.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\src\\pages\\parent\\ParentChildProfile.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\src\\pages\\parent\\ParentDashboard.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchData'. Either include it or remove the dependency array.","line":105,"column":8,"nodeType":"ArrayExpression","endLine":105,"endColumn":16,"suggestions":[{"desc":"Update the dependencies array to be: [fetchData, userId]","fix":{"range":[4426,4434],"text":"[fetchData, userId]"}}]},{"ruleId":"no-unused-vars","severity":2,"message":"'error' is defined but never used.","line":114,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":114,"endColumn":23}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { API_URL } from '../../config';\r\nimport React, { useState, useEffect } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport {\r\n    CalendarCheck,\r\n    Star,\r\n    CreditCard,\r\n    TrendingUp,\r\n    User,\r\n    Clock,\r\n    CheckCircle2,\r\n    AlertCircle,\r\n    BellRing,\r\n    IdCard\r\n} from 'lucide-react';\r\nimport PlayerBadgeModal from '../../components/PlayerBadgeModal';\r\n\r\nconst ParentDashboard = () => {\r\n    const navigate = useNavigate();\r\n    const [childData, setChildData] = useState(null);\r\n    const [subscriptionData, setSubscriptionData] = useState(null);\r\n    const [payments, setPayments] = useState([]);\r\n    const [attendanceRate, setAttendanceRate] = useState('N/A');\r\n    const [performanceScore, setPerformanceScore] = useState('N/A');\r\n    const [upcomingEvent, setUpcomingEvent] = useState(null);\r\n    const [isLoading, setIsLoading] = useState(true);\r\n    const [isSendingTest, setIsSendingTest] = useState(false);\r\n    const [isBadgeModalOpen, setIsBadgeModalOpen] = useState(false);\r\n    const userId = localStorage.getItem('user_id');\r\n\r\n    const fetchData = async () => {\r\n        try {\r\n            // 1. Fetch targeted player for this parent\r\n            const playersRes = await fetch(`${API_URL}/players/parent/${userId}`);\r\n            let child = null;\r\n            if (playersRes.ok) {\r\n                const parentsPlayers = await playersRes.json();\r\n                child = parentsPlayers[0]; // Currently taking the first child\r\n                \r\n                // DEV FALLBACK: If no child found, check if we're a player directly\r\n                if (!child) {\r\n                    const selfRes = await fetch(`${API_URL}/players/`);\r\n                    const all = await selfRes.json();\r\n                    child = all.find(p => p.user_id === userId);\r\n                }\r\n                \r\n                setChildData(child);\r\n            }\r\n\r\n            if (child) {\r\n                // 2. Fetch specific data for the child + overall events + subscription\r\n                const [attendRes, evalRes, payRes, eventsRes, subRes] = await Promise.all([\r\n                    fetch(`${API_URL}/attendance/player/${child.user_id}`),\r\n                    fetch(`${API_URL}/evaluations/?player_id=${child.user_id}`),\r\n                    fetch(`${API_URL}/finances/payments/user/${userId}`),\r\n                    fetch(`${API_URL}/events/`),\r\n                    fetch(`${API_URL}/finances/subscriptions/player/${child.user_id}`)\r\n                ]);\r\n\r\n                if (attendRes.ok) {\r\n                    const attendance = await attendRes.json();\r\n                    if (attendance.length > 0) {\r\n                        const present = attendance.filter(a => a.status === 'present').length;\r\n                        setAttendanceRate(`${Math.round((present / attendance.length) * 100)}%`);\r\n                    }\r\n                }\r\n\r\n                if (evalRes.ok) {\r\n                    const evaluations = await evalRes.json();\r\n                    if (evaluations.length > 0) {\r\n                        const avgRating = evaluations.reduce((sum, e) => sum + e.overall_rating, 0) / evaluations.length;\r\n                        setPerformanceScore(`${avgRating.toFixed(1)}/10`);\r\n                    }\r\n                }\r\n\r\n                if (payRes.ok) {\r\n                    const allPayments = await payRes.json();\r\n                    const childPayments = allPayments.filter(p => p.user_id === child.user_id || p.user_id === userId);\r\n                    setPayments(childPayments.slice(0, 5));\r\n                }\r\n\r\n                if (eventsRes.ok) {\r\n                    const allEvents = await eventsRes.json();\r\n                    const now = new Date();\r\n                    const upcoming = allEvents.filter(e => new Date(e.event_date) >= now).sort((a, b) => new Date(a.event_date) - new Date(b.event_date));\r\n                    if (upcoming.length > 0) {\r\n                        setUpcomingEvent(upcoming[0]);\r\n                    }\r\n                }\r\n\r\n                if (subRes.ok) {\r\n                    const sub = await subRes.json();\r\n                    setSubscriptionData(sub);\r\n                }\r\n            }\r\n        } catch (error) {\r\n            console.error('Error fetching data:', error);\r\n        } finally {\r\n            setIsLoading(false);\r\n        }\r\n    };\r\n\r\n    useEffect(() => {\r\n        fetchData();\r\n    }, [userId]);\r\n\r\n    const handleSendTestNotif = async () => {\r\n        setIsSendingTest(true);\r\n        try {\r\n            const res = await fetch(`${API_URL}/finances/test-notification/${userId}`, { method: 'POST' });\r\n            if (res.ok) {\r\n                alert('Ï¬┘à ÏÑÏ▒Ï│Ïº┘ä Ï¬┘åÏ¿┘è┘ç Ï¬Ï¼Ï▒┘èÏ¿┘è! Ï¬Ï¡┘é┘é ┘à┘å Ïú┘è┘é┘ê┘åÏ® Ïº┘äÏ¼Ï▒Ï│ ┘ü┘è Ïº┘äÏúÏ╣┘ä┘ë.');\r\n            }\r\n        } catch (error) {\r\n            alert('┘üÏ┤┘ä ÏÑÏ▒Ï│Ïº┘ä Ïº┘äÏ¬┘åÏ¿┘è┘ç');\r\n        } finally {\r\n            setIsSendingTest(false);\r\n        }\r\n    };\r\n\r\n    if (isLoading) {\r\n        return (\r\n            <div className=\"flex items-center justify-center h-64\">\r\n                <div className=\"animate-spin rounded-full h-12 w-12 border-b-2 border-sky-600\"></div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    const getPaymentStatus = () => {\r\n        if (!subscriptionData) return { label: 'Up to date', color: 'indigo' };\r\n        const status = subscriptionData.alert_status;\r\n        if (status === 'approaching') return { label: 'Upcoming Payment', color: 'blue' };\r\n        if (status === 'late') return { label: 'Overdue', color: 'amber' };\r\n        if (status === 'suspended') return { label: 'Suspended', color: 'red' };\r\n        return { label: 'Up to date', color: 'emerald' };\r\n    };\r\n\r\n    const payStat = getPaymentStatus();\r\n\r\n    const quickStats = [\r\n        {\r\n            label: 'Ï¡Ïº┘äÏ® Ïº┘ä┘äÏºÏ╣Ï¿',\r\n            value: childData ? '┘åÏ┤ÏÀ' : 'Ï║┘èÏ▒ ┘àÏ¬ÏºÏ¡',\r\n            icon: User,\r\n            color: 'sky',\r\n            bg: 'bg-sky-50',\r\n            text: 'text-sky-600',\r\n            border: 'border-sky-100'\r\n        },\r\n        {\r\n            label: '┘àÏ╣Ï»┘ä Ïº┘äÏ¡ÏÂ┘êÏ▒',\r\n            value: attendanceRate,\r\n            icon: CalendarCheck,\r\n            color: 'emerald',\r\n            bg: 'bg-emerald-50',\r\n            text: 'text-emerald-600',\r\n            border: 'border-emerald-100'\r\n        },\r\n        {\r\n            label: 'Ïº┘äÏ¬┘é┘è┘è┘à Ïº┘äÏ¬┘é┘å┘è',\r\n            value: performanceScore,\r\n            icon: Star,\r\n            color: 'amber',\r\n            bg: 'bg-amber-50',\r\n            text: 'text-amber-600',\r\n            border: 'border-amber-100'\r\n        },\r\n        {\r\n            label: 'Ïº┘ä┘êÏÂÏ╣ Ïº┘ä┘àÏº┘ä┘è',\r\n            value: payStat.label,\r\n            icon: CreditCard,\r\n            color: payStat.color,\r\n            bg: payStat.color === 'emerald' ? 'bg-emerald-50' : payStat.color === 'blue' ? 'bg-blue-50' : payStat.color === 'amber' ? 'bg-amber-50' : payStat.color === 'red' ? 'bg-red-50' : 'bg-indigo-50',\r\n            text: payStat.color === 'emerald' ? 'text-emerald-600' : payStat.color === 'blue' ? 'text-blue-600' : payStat.color === 'amber' ? 'text-amber-600' : payStat.color === 'red' ? 'text-red-600' : 'text-indigo-600',\r\n            border: payStat.color === 'emerald' ? 'border-emerald-100' : payStat.color === 'blue' ? 'border-blue-100' : payStat.color === 'amber' ? 'border-amber-100' : payStat.color === 'red' ? 'border-red-100' : 'border-indigo-100'\r\n        }\r\n    ];\r\n\r\n    return (\r\n        <div className=\"animate-fade-in space-y-8 text-right\" dir=\"rtl\">\r\n            {/* Subscription Alert Banner */}\r\n            {subscriptionData?.alert_status && subscriptionData.alert_status !== 'none' && (\r\n                <div className={`p-4 rounded-2xl border flex items-center justify-between animate-pulse ${\r\n                    subscriptionData.alert_status === 'approaching' ? 'bg-blue-50 border-blue-200 text-blue-700' :\r\n                    subscriptionData.alert_status === 'late' ? 'bg-amber-50 border-amber-200 text-amber-700' :\r\n                    'bg-red-50 border-red-200 text-red-700'\r\n                }`}>\r\n                    <div className=\"flex items-center gap-3\">\r\n                        <AlertCircle size={24} />\r\n                        <div>\r\n                            <p className=\"font-black text-sm uppercase tracking-tight\">ÏÑÏ┤Ï╣ÏºÏ▒ Ïº┘äÏúÏ»ÏºÏí Ïº┘ä┘àÏº┘ä┘è</p>\r\n                            <p className=\"text-xs font-bold opacity-80\">┘å┘êÏ» Ï¬Ï░┘â┘èÏ▒┘â┘à Ï¿ÏÂÏ▒┘êÏ▒Ï® Ï¬Ï│┘ê┘èÏ® ┘àÏ¿┘äÏ║ Ïº┘äÏºÏ┤Ï¬Ï▒Ïº┘â ┘ü┘è Ïú┘éÏ▒Ï¿ ┘ê┘éÏ¬ ┘äÏÂ┘àÏº┘å ÏºÏ│Ï¬┘àÏ▒ÏºÏ▒ Ïº┘äÏ«Ï»┘àÏ®.</p>\r\n                        </div>\r\n                    </div>\r\n                    <button \r\n                        onClick={() => navigate('/parent/payments')}\r\n                        className=\"px-5 py-2 bg-white rounded-xl shadow-sm border border-current font-black text-[10px] uppercase hover:bg-slate-50 transition-all shrink-0\"\r\n                    >\r\n                        Ï╣Ï▒ÏÂ Ïº┘äÏ¬┘üÏºÏÁ┘è┘ä\r\n                    </button>\r\n                </div>\r\n            )}\r\n\r\n            {/* Header */}\r\n            <div className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4\">\r\n                <div>\r\n                    <h1 className=\"text-3xl font-extrabold tracking-tight text-slate-900 mb-1\">\r\n                        ┘àÏ▒Ï¡Ï¿Ïº┘ï Ï¿┘âÏî <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-blue-600\">┘ê┘ä┘è Ïº┘äÏú┘àÏ▒</span>\r\n                    </h1>\r\n                    <p className=\"text-[15px] font-medium text-slate-500\">\r\n                        {childData ? `┘àÏ¬ÏºÏ¿Ï╣Ï® ┘àÏ│ÏºÏ▒ ┘êÏ¬ÏÀ┘êÏ▒ ${childData.full_name}` : '┘åÏ©Ï▒Ï® Ï╣Ïº┘àÏ® Ï╣┘ä┘ë ┘åÏ┤ÏºÏÀ ÏÀ┘ü┘ä┘â ┘ü┘è Ïº┘äÏú┘âÏºÏ»┘è┘à┘èÏ®'}\r\n                    </p>\r\n                </div>\r\n                <button\r\n                    onClick={handleSendTestNotif}\r\n                    disabled={isSendingTest}\r\n                    className=\"flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-indigo-600 to-blue-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest shadow-xl shadow-indigo-500/20 active:scale-95 transition-all disabled:opacity-50\"\r\n                >\r\n                    <BellRing size={16} className={isSendingTest ? 'animate-bounce' : ''} />\r\n                    {isSendingTest ? 'Ï¼ÏºÏ▒┘è Ïº┘äÏÑÏ▒Ï│Ïº┘ä...' : 'ÏºÏ«Ï¬Ï¿ÏºÏ▒ Ï¬┘åÏ¿┘è┘ç Ïº┘äÏúÏ»ÏºÏí'}\r\n                </button>\r\n            </div>\r\n\r\n            {/* Stats Grid */}\r\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\r\n                {quickStats.map((stat, i) => {\r\n                    const Icon = stat.icon;\r\n                    return (\r\n                        <div key={i} className=\"bg-white p-6 rounded-2xl border border-slate-200 premium-shadow group hover:border-sky-300 transition-all relative overflow-hidden\">\r\n                            <div className=\"absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity\">\r\n                                <Icon size={80} />\r\n                            </div>\r\n                            <div className=\"flex items-center justify-between mb-4 relative z-10\">\r\n                                <div className={`p-3 rounded-xl border ${stat.bg} ${stat.text} ${stat.border}`}>\r\n                                    <Icon size={22} strokeWidth={2.5} />\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"relative z-10\">\r\n                                <h4 className=\"text-2xl font-black text-slate-800 tracking-tight mb-1\">{stat.value}</h4>\r\n                                <p className=\"text-sm font-semibold text-slate-500\">{stat.label}</p>\r\n                            </div>\r\n                        </div>\r\n                    );\r\n                })}\r\n            </div>\r\n\r\n            <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\r\n                {/* Child Info Card */}\r\n                {childData && (\r\n                    <div className=\"bg-white rounded-[2.5rem] border border-slate-200 premium-shadow overflow-hidden p-2\">\r\n                        <div className=\"px-6 py-5 rounded-3xl bg-sky-50 flex items-center justify-between\">\r\n                            <div className=\"flex items-center gap-3\">\r\n                                <User size={20} className=\"text-sky-600\" />\r\n                                <h3 className=\"font-extrabold text-slate-800 text-lg\">┘à┘ä┘ü Ïº┘ä┘äÏºÏ╣Ï¿</h3>\r\n                            </div>\r\n                            <button \r\n                                onClick={() => setIsBadgeModalOpen(true)}\r\n                                className=\"flex items-center gap-2 px-4 py-2 bg-white border border-sky-200 rounded-xl text-sky-600 font-bold text-xs hover:bg-sky-50 transition-all shadow-sm\"\r\n                            >\r\n                                <IdCard size={16} />\r\n                                Ï¿ÏÀÏº┘éÏ® Ïº┘ä┘äÏºÏ╣Ï¿\r\n                            </button>\r\n                        </div>\r\n                        <div className=\"p-6 space-y-6\">\r\n                            <div className=\"flex items-center gap-4\">\r\n                                <div className=\"w-16 h-16 rounded-[1.5rem] bg-gradient-to-br from-sky-500 to-blue-600 flex items-center justify-center text-white text-2xl font-black shadow-lg\">\r\n                                    {childData.full_name?.[0] || '?'}\r\n                                </div>\r\n                                <div>\r\n                                    <h4 className=\"text-xl font-extrabold text-slate-900\">{childData.full_name}</h4>\r\n                                    <p className=\"text-sm font-medium text-slate-500\">{childData.u_category || childData.category || 'Ï║┘èÏ▒ ┘àÏ¡Ï»Ï»'}</p>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"grid grid-cols-2 gap-4 mt-4\">\r\n                                <div className=\"bg-slate-50 rounded-2xl p-4\">\r\n                                    <p className=\"text-[11px] font-black uppercase tracking-widest text-slate-400 mb-1\">Ïº┘ä┘àÏ▒┘âÏ▓</p>\r\n                                    <p className=\"text-sm font-bold text-slate-800\">{childData.position || 'Ï║┘èÏ▒ ┘àÏ¡Ï»Ï»'}</p>\r\n                                </div>\r\n                                <div className=\"bg-slate-50 rounded-2xl p-4\">\r\n                                    <p className=\"text-[11px] font-black uppercase tracking-widest text-slate-400 mb-1\">Ïº┘ä┘üÏªÏ®</p>\r\n                                    <p className=\"text-sm font-bold text-slate-800\">{childData.u_category || childData.category || 'N/A'}</p>\r\n                                </div>\r\n                                <div className=\"bg-slate-50 rounded-2xl p-4\">\r\n                                    <p className=\"text-[11px] font-black uppercase tracking-widest text-slate-400 mb-1\">Ïº┘äÏ¡Ïº┘äÏ®</p>\r\n                                    <p className=\"text-sm font-bold text-emerald-600\">┘åÏ┤ÏÀ</p>\r\n                                </div>\r\n                                <div className=\"bg-slate-50 rounded-2xl p-4\">\r\n                                    <p className=\"text-[11px] font-black uppercase tracking-widest text-slate-400 mb-1\">Ï¬ÏºÏ▒┘èÏ« Ïº┘äÏº┘åÏÂ┘àÏº┘à</p>\r\n                                    <p className=\"text-sm font-bold text-slate-800 text-left\" dir=\"ltr\">\r\n                                        {childData.created_at ? new Date(childData.created_at).toLocaleDateString() : 'N/A'}\r\n                                    </p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                )}\r\n\r\n                {/* Recent Payments */}\r\n                <div className=\"bg-white rounded-[2.5rem] border border-slate-200 premium-shadow overflow-hidden p-2\">\r\n                    <div className=\"px-6 py-5 rounded-3xl bg-slate-50 flex items-center gap-3\">\r\n                        <CreditCard size={20} className=\"text-indigo-600\" />\r\n                        <h3 className=\"font-extrabold text-slate-800 text-lg\">Ïº┘ä┘àÏ»┘ü┘êÏ╣ÏºÏ¬ Ïº┘äÏúÏ«┘èÏ▒Ï®</h3>\r\n                    </div>\r\n                    <div className=\"divide-y divide-slate-100 px-2\">\r\n                        {payments.length === 0 ? (\r\n                            <div className=\"p-10 text-center text-slate-400 font-bold italic\">┘äÏº Ï¬┘êÏ¼Ï» Ï│Ï¼┘äÏºÏ¬ ┘àÏº┘ä┘èÏ® ┘àÏ¬┘ê┘üÏ▒Ï®.</div>\r\n                        ) : payments.map((payment, i) => (\r\n                            <div key={i} className=\"p-5 flex items-center justify-between hover:bg-slate-50/50 transition-colors\">\r\n                                <div className=\"flex items-center gap-3\">\r\n                                    <div className={`w-10 h-10 rounded-2xl flex items-center justify-center ${payment.status === 'paid' ? 'bg-emerald-50 text-emerald-600' : 'bg-amber-50 text-amber-600'}`}>\r\n                                        {payment.status === 'paid' ? <CheckCircle2 size={18} /> : <Clock size={18} />}\r\n                                    </div>\r\n                                    <div>\r\n                                        <p className=\"text-sm font-bold text-slate-900\">{payment.payment_type === 'subscription' ? 'ÏºÏ┤Ï¬Ï▒Ïº┘â Ï┤┘çÏ▒┘è' : 'Ï¬Ïú┘à┘è┘å Ïú┘ê Ï▒Ï│┘ê┘à ÏúÏ«Ï▒┘ë'}</p>\r\n                                        <p className=\"text-xs text-slate-500 text-left\" dir=\"ltr\">{payment.payment_date ? new Date(payment.payment_date).toLocaleDateString() : 'N/A'}</p>\r\n                                    </div>\r\n                                </div>\r\n                                <span className=\"font-black text-slate-900 bg-slate-100 px-3 py-1 rounded-xl\">{payment.amount} Ï»Ï▒┘ç┘à</span>\r\n                            </div>\r\n                        ))}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Next Training */}\r\n            <div className=\"bg-gradient-to-br from-indigo-50 to-blue-50 rounded-[2.5rem] border border-indigo-100 premium-shadow p-6 sm:p-8\">\r\n                <div className=\"flex items-center gap-3 mb-6\">\r\n                    <div className=\"p-3 bg-indigo-100 text-indigo-600 rounded-2xl\">\r\n                        <CalendarCheck size={24} strokeWidth={2.5} />\r\n                    </div>\r\n                    <h3 className=\"font-black text-slate-800 text-xl tracking-tight\">Ïº┘äÏ¼Ï»┘ê┘ä Ïº┘ä┘éÏºÏ»┘à</h3>\r\n                </div>\r\n                {upcomingEvent ? (\r\n                    <div className=\"bg-white/80 rounded-3xl p-6 border border-white flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 shadow-sm\">\r\n                        <div className=\"flex items-center gap-4\">\r\n                            <div className=\"w-14 h-14 bg-indigo-600 rounded-2xl text-white flex flex-col items-center justify-center flex-shrink-0\">\r\n                                <span className=\"text-xs font-black uppercase tracking-widest\">{new Date(upcomingEvent.event_date).toLocaleDateString('default', { month: 'short' })}</span>\r\n                                <span className=\"text-xl font-extrabold leading-tight\">{new Date(upcomingEvent.event_date).getDate()}</span>\r\n                            </div>\r\n                            <div>\r\n                                <h4 className=\"text-lg font-black text-slate-900\">{upcomingEvent.title}</h4>\r\n                                <div className=\"flex items-center gap-2 mt-1\">\r\n                                    <p className=\"text-sm font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-lg flex items-center gap-1.5\"><Clock size={14}/> {upcomingEvent.event_time.substring(0, 5)}</p>\r\n                                    {upcomingEvent.location && <p className=\"text-sm font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-lg\">{upcomingEvent.location}</p>}\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div className=\"text-right sm:text-left self-start sm:self-center\">\r\n                            <span className={`px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest ${upcomingEvent.type === 'Match' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'}`}>\r\n                                {upcomingEvent.type === 'Match' ? '┘àÏ¿ÏºÏ▒ÏºÏ®' : 'Ï¬Ï»Ï▒┘èÏ¿'}\r\n                            </span>\r\n                        </div>\r\n                    </div>\r\n                ) : (\r\n                    <div className=\"bg-white/60 rounded-3xl p-8 border border-white text-center shadow-sm\">\r\n                        <div className=\"w-16 h-16 bg-blue-100 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-4\">\r\n                           <CalendarCheck size={32} />\r\n                        </div>\r\n                        <p className=\"text-base font-black text-slate-700\">┘äÏº ┘è┘êÏ¼Ï» Ïú┘è ┘åÏ┤ÏºÏÀ ┘àÏ¿Ï▒┘àÏ¼ Ï¡Ïº┘ä┘èÏº┘ï.</p>\r\n                        <p className=\"text-sm font-bold text-slate-500 mt-1\">Ï│┘å┘é┘ê┘à Ï¿ÏÑÏ┤Ï╣ÏºÏ▒┘â Ï╣┘åÏ» Ï¿Ï▒┘àÏ¼Ï® ┘åÏ┤ÏºÏÀ Ï¼Ï»┘èÏ».</p>\r\n                    </div>\r\n                )}\r\n            </div>\r\n            {/* Player Badge Modal */}\r\n            {childData && (\r\n                <PlayerBadgeModal \r\n                    isOpen={isBadgeModalOpen}\r\n                    onClose={() => setIsBadgeModalOpen(false)}\r\n                    player={childData}\r\n                />\r\n            )}\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default ParentDashboard;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\src\\pages\\parent\\ParentEvaluations.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'useRef' is defined but never used. Allowed unused vars must match /^[A-Z_]/u.","line":2,"column":38,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":44,"suggestions":[{"messageId":"removeVar","data":{"varName":"useRef"},"fix":{"range":[76,84],"text":""},"desc":"Remove unused variable 'useRef'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'isBadgeModalOpen' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":20,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":20,"endColumn":28,"suggestions":[{"messageId":"removeVar","data":{"varName":"isBadgeModalOpen"},"fix":{"range":[967,983],"text":""},"desc":"Remove unused variable 'isBadgeModalOpen'."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { API_URL } from '../../config';\r\nimport React, { useState, useEffect, useRef } from 'react';\r\nimport { Star, TrendingUp, Award, Download, XCircle, IdCard } from 'lucide-react';\r\nimport PlayerBadgeModal from '../../components/PlayerBadgeModal';\r\nimport FUTCard from '../../components/FUTCard';\r\nimport html2canvas from 'html2canvas';\r\n\r\nconst skills = [\r\n    { key: 'technical_score', label: 'Ïº┘äÏ¬┘é┘è┘è┘à Ïº┘äÏ¬┘é┘å┘è', color: 'bg-blue-500' },\r\n    { key: 'tactical_score', label: 'Ïº┘äÏ¬┘é┘è┘è┘à Ïº┘äÏ¬┘âÏ¬┘è┘â┘è', color: 'bg-emerald-500' },\r\n    { key: 'physical_score', label: 'Ïº┘ä┘ä┘èÏº┘éÏ® Ïº┘äÏ¿Ï»┘å┘èÏ®', color: 'bg-purple-500' },\r\n    { key: 'mental_score', label: 'Ïº┘ä┘é┘êÏ® Ïº┘äÏ░┘ç┘å┘èÏ®', color: 'bg-amber-500' }\r\n];\r\n\r\nconst ParentEvaluations = () => {\r\n    const [evaluations, setEvaluations] = useState([]);\r\n    const [childInfo, setChildInfo] = useState(null);\r\n    const [isLoading, setIsLoading] = useState(true);\r\n    const [showCardModal, setShowCardModal] = useState(false);\r\n    const [isBadgeModalOpen, setIsBadgeModalOpen] = useState(false);\r\n    const userId = localStorage.getItem('user_id');\r\n\r\n    useEffect(() => {\r\n        const fetchEvaluations = async () => {\r\n            try {\r\n                const parentsPlayersRes = await fetch(`${API_URL}/players/parent/${userId}`);\r\n                if (parentsPlayersRes.ok) {\r\n                    const parentsPlayers = await parentsPlayersRes.json();\r\n                    let child = parentsPlayers[0];\r\n                    \r\n                    // DEV FALLBACK: If no child found directly, try finding self as player\r\n                    if (!child) {\r\n                        const allRes = await fetch(`${API_URL}/players/`);\r\n                        const all = await allRes.json();\r\n                        child = all.find(p => p.user_id === userId);\r\n                    }\r\n\r\n                    if (child) {\r\n                        setChildInfo(child);\r\n                        const evalRes = await fetch(`${API_URL}/evaluations/?player_id=${child.user_id}`);\r\n                        if (evalRes.ok) {\r\n                            let data = await evalRes.json();\r\n                            \r\n                            // If specifically John Doe and we got nothing, but he has evals, \r\n                            // maybe there's a filtering mismatch. Let's try fetching all if empty.\r\n                            if (data.length === 0) {\r\n                                const allEvalsRes = await fetch(`${API_URL}/evaluations/`);\r\n                                if (allEvalsRes.ok) {\r\n                                    const allEvals = await allEvalsRes.json();\r\n                                    data = allEvals.filter(e => e.player_id === child.user_id);\r\n                                }\r\n                            }\r\n                            // Sort by date descending\r\n                            data.sort((a,b) => new Date(b.evaluation_date) - new Date(a.evaluation_date));\r\n                            setEvaluations(data);\r\n                        }\r\n                    }\r\n                }\r\n            } catch (error) {\r\n                console.error('Error:', error);\r\n            } finally {\r\n                setIsLoading(false);\r\n            }\r\n        };\r\n        fetchEvaluations();\r\n    }, [userId]);\r\n\r\n    if (isLoading) {\r\n        return (\r\n            <div className=\"flex items-center justify-center h-64\">\r\n                <div className=\"animate-spin rounded-full h-12 w-12 border-b-2 border-sky-600\"></div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    const avgScores = {};\r\n    skills.forEach(s => {\r\n        const values = evaluations.map(e => e[s.key] || 0).filter(v => v > 0);\r\n        avgScores[s.key] = values.length > 0 ? (values.reduce((a, b) => a + b, 0) / values.length).toFixed(1) : 0;\r\n    });\r\n    const overallAvg = Object.values(avgScores).filter(v => v > 0).length > 0\r\n        ? (Object.values(avgScores).reduce((a, b) => parseFloat(a) + parseFloat(b), 0) / Object.values(avgScores).filter(v => v > 0).length).toFixed(1)\r\n        : 0;\r\n\r\n    const latestEvaluation = evaluations.length > 0 ? evaluations[0] : null;\r\n\r\n    const handleDownloadCard = async () => {\r\n        const element = document.getElementById('fut-card-container');\r\n        if (!element) return;\r\n        \r\n        try {\r\n            const canvas = await html2canvas(element, { backgroundColor: null, scale: 2 });\r\n            const dataUrl = canvas.toDataURL('image/png');\r\n            const link = document.createElement('a');\r\n            link.download = `fut-card-${childInfo?.full_name || 'player'}.png`;\r\n            link.href = dataUrl;\r\n            link.click();\r\n        } catch (err) {\r\n            console.error('Failed to download image', err);\r\n        }\r\n    };\r\n\r\n    return (\r\n        <div className=\"animate-fade-in space-y-8 text-right\" dir=\"rtl\">\r\n            <div className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4\">\r\n                <div>\r\n                    <h1 className=\"text-3xl font-extrabold tracking-tight text-slate-900 mb-1\">\r\n                        Ï¬┘éÏ▒┘èÏ▒ <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-blue-600\">Ïº┘äÏúÏ»ÏºÏí</span>\r\n                    </h1>\r\n                    <p className=\"text-[15px] font-medium text-slate-500\">┘àÏ¬ÏºÏ¿Ï╣Ï® Ïº┘äÏ¬┘é┘è┘è┘àÏºÏ¬ Ïº┘äÏ»┘êÏ▒┘èÏ® ┘ä┘à┘çÏºÏ▒ÏºÏ¬ ÏÀ┘ü┘ä┘â ┘à┘å ÏÀÏ▒┘ü Ïº┘ä┘àÏ»Ï▒Ï¿┘è┘å</p>\r\n                </div>\r\n                <div className=\"flex items-center gap-3\">\r\n                    {latestEvaluation && (\r\n                        <button\r\n                            onClick={() => setShowCardModal(true)}\r\n                            className=\"flex items-center gap-2 bg-gradient-to-r from-yellow-400 to-yellow-600 text-white px-5 py-2.5 rounded-xl font-black uppercase tracking-widest text-[10px] hover:scale-105 transition-transform shadow-lg shadow-yellow-500/30\"\r\n                        >\r\n                            <Award size={16} /> FUT Card\r\n                        </button>\r\n                    )}\r\n                    <button\r\n                        onClick={() => setIsBadgeModalOpen(true)}\r\n                        className=\"flex items-center gap-2 bg-white border border-slate-200 text-slate-700 px-5 py-2.5 rounded-xl font-black uppercase tracking-widest text-[10px] hover:bg-slate-50 transition-all shadow-sm\"\r\n                    >\r\n                        <IdCard size={16} /> Ï¿ÏÀÏº┘éÏ® Ïº┘äÏ¬Ï╣Ï▒┘è┘ü\r\n                    </button>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Overall Score */}\r\n            <div className=\"bg-gradient-to-br from-sky-500 to-blue-600 rounded-[2.5rem] p-8 text-white premium-shadow relative overflow-hidden\">\r\n                <div className=\"absolute left-10 top-0 w-32 h-32 bg-white/10 rounded-full -translate-y-1/2 blur-2xl\"></div>\r\n                <div className=\"flex items-center gap-6\">\r\n                    <div className=\"w-20 h-20 rounded-[1.5rem] bg-white/20 backdrop-blur-sm flex items-center justify-center border-2 border-white/30 shrink-0\">\r\n                        <span className=\"text-4xl font-black\">{overallAvg}</span>\r\n                    </div>\r\n                    <div>\r\n                        <h2 className=\"text-2xl font-black\">Ïº┘äÏ¬┘é┘è┘è┘à Ïº┘äÏ╣Ïº┘à</h2>\r\n                        <p className=\"text-sky-100 font-bold mt-1\">Ï¿┘åÏºÏí┘ï Ï╣┘ä┘ë {evaluations.length} Ï¬┘é┘è┘è┘à{evaluations.length > 2 && evaluations.length < 11 ? 'ÏºÏ¬' : ''} ┘àÏ╣Ï¬┘àÏ»</p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Skill Bars */}\r\n            <div className=\"bg-white rounded-[2.5rem] border border-slate-200 premium-shadow p-8 space-y-6\">\r\n                <div className=\"flex items-center gap-3 mb-4\">\r\n                    <div className=\"p-2 bg-sky-50 rounded-xl\">\r\n                       <TrendingUp size={24} className=\"text-sky-600\" />\r\n                    </div>\r\n                    <h3 className=\"font-extrabold text-slate-800 text-lg\">Ï¬Ï¡┘ä┘è┘ä Ïº┘ä┘à┘çÏºÏ▒ÏºÏ¬</h3>\r\n                </div>\r\n                {skills.map(skill => {\r\n                    const score = parseFloat(avgScores[skill.key]) || 0;\r\n                    const percentage = (score / 10) * 100;\r\n                    return (\r\n                        <div key={skill.key}>\r\n                            <div className=\"flex justify-between mb-2\">\r\n                                <span className=\"text-sm font-bold text-slate-700\">{skill.label}</span>\r\n                                <span className=\"text-sm font-black text-slate-900\">{score}/10</span>\r\n                            </div>\r\n                            <div className=\"w-full bg-slate-100 rounded-full h-3 overflow-hidden\">\r\n                                <div className={`h-full rounded-full ${skill.color} transition-all duration-700`} style={{ width: `${percentage}%` }}></div>\r\n                            </div>\r\n                        </div>\r\n                    );\r\n                })}\r\n            </div>\r\n\r\n            {/* Evaluation History */}\r\n            <div className=\"bg-white rounded-[2.5rem] border border-slate-200 premium-shadow overflow-hidden p-2\">\r\n                <div className=\"px-6 py-5 rounded-3xl bg-slate-50 flex items-center justify-between pointer-events-none\">\r\n                    <h3 className=\"font-extrabold text-slate-800 text-lg\">Ï│Ï¼┘ä Ïº┘äÏ¬┘é┘è┘è┘àÏºÏ¬</h3>\r\n                    <span className=\"text-xs font-black text-slate-400 bg-white px-3 py-1.5 rounded-xl border border-slate-200\">{evaluations.length} ÏÑÏ¼┘àÏº┘ä┘è</span>\r\n                </div>\r\n                {evaluations.length === 0 ? (\r\n                    <div className=\"p-12 text-center\">\r\n                        <Star className=\"mx-auto text-slate-200 mb-4\" size={48} />\r\n                        <h4 className=\"font-bold text-slate-800 mb-2\">┘äÏº Ï¬┘êÏ¼Ï» Ï¬┘é┘è┘è┘àÏºÏ¬ Ï¿Ï╣Ï»</h4>\r\n                        <p className=\"text-sm text-slate-500\">┘ä┘à ┘èÏ¬┘à Ï¬┘é┘è┘è┘à ÏÀ┘ü┘ä┘â Ï¿Ï╣Ï» ┘à┘å ÏÀÏ▒┘ü Ïº┘äÏÀÏº┘é┘à Ïº┘äÏ¬┘é┘å┘è. ┘èÏ▒Ï¼┘ë Ïº┘ä┘àÏ▒ÏºÏ¼Ï╣Ï® ┘äÏºÏ¡┘éÏº┘ï.</p>\r\n                    </div>\r\n                ) : (\r\n                    <div className=\"divide-y divide-slate-100\">\r\n                        {evaluations.map((ev, i) => {\r\n                            const avg = skills.reduce((sum, s) => sum + (ev[s.key] || 0), 0) / skills.length;\r\n                            return (\r\n                                <div key={i} className=\"p-6 hover:bg-slate-50/50 transition-colors\">\r\n                                    <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4\">\r\n                                        <div className=\"flex items-center gap-3\">\r\n                                            <div className=\"w-12 h-12 rounded-2xl bg-sky-50 text-sky-600 font-black text-lg flex items-center justify-center shrink-0 border border-sky-100\">\r\n                                                {avg.toFixed(1)}\r\n                                            </div>\r\n                                            <div>\r\n                                                <p className=\"font-bold text-slate-900\" dir=\"ltr\">\r\n                                                    {ev.evaluation_date ? new Date(ev.evaluation_date).toLocaleDateString('en-GB') : 'N/A'}\r\n                                                </p>\r\n                                                {ev.notes && <p className=\"text-sm text-slate-500 mt-1 max-w-sm leading-relaxed\">{ev.notes}</p>}\r\n                                            </div>\r\n                                        </div>\r\n                                        <div className=\"flex items-center gap-1 bg-slate-50 p-2 rounded-xl border border-slate-100\">\r\n                                            {[...Array(5)].map((_, idx) => (\r\n                                                <Star key={idx} size={14} className={idx < Math.round(avg / 2) ? 'text-amber-400 fill-amber-400' : 'text-slate-200'} />\r\n                                            ))}\r\n                                        </div>\r\n                                    </div>\r\n                                    <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3\">\r\n                                        {skills.map(skill => (\r\n                                            <div key={skill.key} className=\"text-center bg-slate-50 border border-slate-100 rounded-xl py-2\">\r\n                                                <div className=\"text-[10px] font-black uppercase tracking-wider text-slate-400 mb-0.5\">{skill.label}</div>\r\n                                                <div className=\"text-lg font-black text-slate-800\">{ev[skill.key] || '-'}</div>\r\n                                            </div>\r\n                                        ))}\r\n                                    </div>\r\n                                </div>\r\n                            );\r\n                        })}\r\n                    </div>\r\n                )}\r\n            </div>\r\n\r\n            {/* FUT Card Modal */}\r\n            {showCardModal && latestEvaluation && childInfo && (\r\n                <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/80 backdrop-blur-sm animate-in fade-in duration-200\">\r\n                    <div className=\"bg-slate-800 rounded-[2.5rem] p-8 w-full max-w-sm relative flex flex-col items-center border border-slate-700 shadow-2xl\">\r\n                        <button \r\n                            onClick={() => setShowCardModal(false)}\r\n                            className=\"absolute top-4 right-4 bg-white/10 text-white/50 hover:bg-white/20 hover:text-white rounded-full p-2 transition-all\"\r\n                        >\r\n                            <XCircle size={24}/>\r\n                        </button>\r\n                        <h3 className=\"font-black text-yellow-500 text-lg mb-8 tracking-widest uppercase mt-2\">Ï¿ÏÀÏº┘éÏ® Ïº┘ä┘äÏºÏ╣Ï¿ Ïº┘äÏ▒Ï│┘à┘èÏ®</h3>\r\n                        \r\n                        <div id=\"fut-card-container\" className=\"mb-8\">\r\n                            <FUTCard player={childInfo} evaluation={latestEvaluation} />\r\n                        </div>\r\n\r\n                        <button \r\n                            onClick={handleDownloadCard} \r\n                            className=\"flex items-center gap-2 bg-gradient-to-r from-yellow-500 to-yellow-600 text-slate-900 px-6 py-3 rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-yellow-500/20 hover:scale-105 transition-all text-sm\"\r\n                        >\r\n                            <Download size={18} /> Ï¬Ï¡┘à┘è┘ä Ïº┘äÏ¿ÏÀÏº┘éÏ®\r\n                        </button>\r\n                    </div>\r\n                </div>\r\n            )}\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default ParentEvaluations;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\src\\pages\\parent\\ParentLayout.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'isRTL' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":23,"column":16,"nodeType":"Identifier","messageId":"unusedVar","endLine":23,"endColumn":21,"suggestions":[{"messageId":"removeVar","data":{"varName":"isRTL"},"fix":{"range":[693,700],"text":""},"desc":"Remove unused variable 'isRTL'."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState } from 'react';\r\nimport { Outlet, Navigate, useNavigate, useLocation } from 'react-router-dom';\r\nimport {\r\n    LayoutDashboard,\r\n    LogOut,\r\n    Menu,\r\n    X,\r\n    CalendarCheck,\r\n    Star,\r\n    CreditCard,\r\n    User,\r\n    GraduationCap,\r\n    MessageCircle\r\n} from 'lucide-react';\r\nimport NotificationsDropdown from '../../components/NotificationsDropdown';\r\nimport LanguageSwitcher from '../../components/LanguageSwitcher';\r\nimport { useLanguage } from '../../i18n/LanguageContext';\r\n\r\nconst ParentLayout = () => {\r\n    const navigate = useNavigate();\r\n    const location = useLocation();\r\n    const [isSidebarOpen, setIsSidebarOpen] = useState(true);\r\n    const { t, isRTL } = useLanguage();\r\n\r\n    const token = localStorage.getItem('token');\r\n    const role = localStorage.getItem('role');\r\n\r\n    if (!token || role !== 'parent') {\r\n        return <Navigate to=\"/login\" replace />;\r\n    }\r\n\r\n    const navItems = [\r\n        { path: '/parent/dashboard', name: t('sidebar.dashboard'), icon: LayoutDashboard },\r\n        { path: '/parent/child', name: t('parent.playerProfile'), icon: User },\r\n        { path: '/parent/attendance', name: t('sidebar.attendance'), icon: CalendarCheck },\r\n        { path: '/parent/evaluations', name: t('sidebar.evaluations'), icon: Star },\r\n        { path: '/parent/payments', name: t('sidebar.finances'), icon: CreditCard },\r\n        { path: '/parent/chat', name: t('sidebar.chat') || 'Chat', icon: MessageCircle }\r\n    ];\r\n\r\n    const handleLogout = () => {\r\n        localStorage.removeItem('token');\r\n        localStorage.removeItem('role');\r\n        localStorage.removeItem('user_id');\r\n        navigate('/login');\r\n    };\r\n\r\n    return (\r\n        <div className=\"min-h-screen bg-slate-50 relative flex overflow-hidden\">\r\n            {/* Mobile Sidebar Overlay */}\r\n            {!isSidebarOpen && (\r\n                <div\r\n                    className=\"fixed inset-0 bg-slate-900/50 z-40 lg:hidden\"\r\n                    onClick={() => setIsSidebarOpen(true)}\r\n                />\r\n            )}\r\n\r\n            {/* Sidebar */}\r\n            <aside\r\n                className={`\r\n                    fixed lg:static inset-y-0 left-0 z-50\r\n                    bg-white border-r border-slate-200 \r\n                    transition-all duration-300 ease-in-out\r\n                    flex flex-col shrink-0 overflow-hidden\r\n                    ${isSidebarOpen ? 'w-72 translate-x-0' : 'w-0 -translate-x-full lg:translate-x-0 lg:w-20'}\r\n                `}\r\n            >\r\n                <div className=\"w-72 h-full flex flex-col\">\r\n                    <div className=\"h-20 flex items-center px-6 border-b border-slate-100 shrink-0\">\r\n                    <div className=\"flex items-center gap-3\">\r\n                        <div className=\"w-10 h-10 bg-gradient-to-tr from-sky-500 to-blue-600 rounded-xl flex items-center justify-center shadow-lg transform rotate-3\">\r\n                            <GraduationCap className=\"text-white -rotate-3\" size={22} />\r\n                        </div>\r\n                        <div>\r\n                            <span className=\"text-xl font-extrabold text-slate-800 tracking-tight block leading-tight\">Parent</span>\r\n                            <span className=\"text-[11px] font-bold text-sky-600 tracking-wider uppercase\">Portal</span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"flex-1 overflow-y-auto p-4 space-y-1\">\r\n                    {navItems.map((item) => {\r\n                        const Icon = item.icon;\r\n                        const isActive = location.pathname.includes(item.path);\r\n\r\n                        return (\r\n                            <button\r\n                                key={item.path}\r\n                                onClick={() => navigate(item.path)}\r\n                                className={`\r\n                                    w-full flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all\r\n                                    ${isActive\r\n                                        ? 'bg-sky-50 text-sky-700'\r\n                                        : 'text-slate-500 hover:bg-slate-50 hover:text-slate-900'}\r\n                                `}\r\n                            >\r\n                                <Icon size={20} className={isActive ? 'text-sky-600' : 'text-slate-400'} />\r\n                                {item.name}\r\n                            </button>\r\n                        );\r\n                    })}\r\n                </div>\r\n\r\n                <div className=\"p-4 border-t border-slate-100\">\r\n                    <button\r\n                        onClick={handleLogout}\r\n                        className=\"w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-bold text-red-600 bg-red-50 hover:bg-red-100 transition-colors\"\r\n                    >\r\n                        <LogOut size={18} />\r\n                        {t('common.logout')}\r\n                    </button>\r\n                </div>\r\n                </div>\r\n            </aside>\r\n\r\n            {/* Main Content */}\r\n            <main className=\"flex-1 flex flex-col min-w-0 h-screen overflow-hidden\">\r\n                <header className=\"h-20 bg-white border-b border-slate-200 flex items-center px-4 lg:px-8 justify-between shrink-0 transition-all\">\r\n                    <button\r\n                        onClick={() => setIsSidebarOpen(!isSidebarOpen)}\r\n                        className=\"p-2 text-slate-500 hover:bg-slate-100 rounded-lg transition-colors border border-slate-200 shadow-sm bg-white\"\r\n                    >\r\n                        {isSidebarOpen ? <X size={20} className=\"lg:hidden\" /> : <Menu size={20} />}\r\n                        {isSidebarOpen && <Menu size={20} className=\"hidden lg:block\" />}\r\n                    </button>\r\n\r\n                    <div className=\"flex items-center gap-4 ml-auto\">\r\n                        <LanguageSwitcher />\r\n                        <NotificationsDropdown />\r\n                        <div className=\"h-8 w-px bg-slate-200 mx-2 hidden sm:block\"></div>\r\n                        <div className=\"hidden sm:flex flex-col items-end\">\r\n                            <span className=\"text-sm font-bold text-slate-800\">Parent Account</span>\r\n                            <span className=\"text-[11px] font-medium text-sky-600 uppercase tracking-widest\">Active</span>\r\n                        </div>\r\n                        <div className=\"w-11 h-11 bg-slate-100 rounded-full border-2 border-white shadow-sm flex items-center justify-center overflow-hidden\">\r\n                            <img src=\"https://ui-avatars.com/api/?name=Parent&background=0ea5e9&color=fff\" alt=\"Parent\" className=\"w-full h-full object-cover\" />\r\n                        </div>\r\n                    </div>\r\n                </header>\r\n\r\n                {location.pathname.includes('/chat') ? (\r\n                    <div className=\"flex-1 overflow-hidden\">\r\n                        <Outlet />\r\n                    </div>\r\n                ) : (\r\n                    <div className=\"flex-1 overflow-auto bg-slate-50/50 p-4 lg:p-8\">\r\n                        <div className=\"max-w-7xl mx-auto\">\r\n                            <Outlet />\r\n                        </div>\r\n                    </div>\r\n                )}\r\n            </main>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default ParentLayout;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\src\\pages\\parent\\ParentPayments.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchPayments'. Either include it or remove the dependency array.","line":49,"column":8,"nodeType":"ArrayExpression","endLine":49,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [fetchPayments]","fix":{"range":[1830,1832],"text":"[fetchPayments]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { API_URL } from '../../config';\nimport React, { useState, useEffect } from 'react';\nimport { CreditCard, CheckCircle2, Clock, AlertTriangle, TrendingUp, Upload, X, Camera, Send } from 'lucide-react';\n\nconst ParentPayments = () => {\n    const [payments, setPayments] = useState([]);\n    const [isLoading, setIsLoading] = useState(true);\n    const [childInfo, setChildInfo] = useState(null);\n    const [isUploadModalOpen, setIsUploadModalOpen] = useState(false);\n    const [isUploading, setIsUploading] = useState(false);\n    \n    // Upload form state\n    const [uploadData, setUploadData] = useState({\n        amount: '',\n        payment_method: 'Bank Transfer',\n        notes: ''\n    });\n\n    const userId = localStorage.getItem('user_id');\n\n    const fetchPayments = async () => {\n        try {\n            let childUserId = null;\n            const playersRes = await fetch(`${API_URL}/players/`);\n            if (playersRes.ok) {\n                const players = await playersRes.json();\n                const child = players.find(p => p.user_id === userId || p.parent_id === userId) || players[0];\n                if (child) {\n                    childUserId = child.user_id;\n                    setChildInfo(child);\n                }\n            }\n\n            const res = await fetch(`${API_URL}/finances/payments`);\n            if (res.ok) {\n                const allPayments = await res.json();\n                const filtered = allPayments.filter(p => p.user_id === childUserId || p.user_id === userId);\n                setPayments(filtered.sort((a, b) => new Date(b.created_at) - new Date(a.created_at)));\n            }\n        } catch (error) {\n            console.error('Error:', error);\n        } finally {\n            setIsLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchPayments();\n    }, []);\n\n    const handleUploadSubmit = async (e) => {\n        e.preventDefault();\n        setIsUploading(true);\n\n        try {\n            // MVP: Simulate file upload, we just send a \"Pending\" payment to the backend\n            const payload = {\n                user_id: childInfo?.user_id || userId,\n                player_id: childInfo?.id || null,\n                amount: parseFloat(uploadData.amount),\n                status: 'Pending',\n                payment_method: uploadData.payment_method,\n                notes: `Ï¬┘à Ï▒┘üÏ╣ ÏÑ┘èÏÁÏº┘ä: ${uploadData.notes}`,\n                billing_type: 'monthly',\n                payment_date: new Date().toISOString()\n            };\n\n            const res = await fetch(`${API_URL}/finances/payments`, {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify(payload)\n            });\n\n            if (res.ok) {\n                alert('Ï¬┘à ÏÑÏ▒Ï│Ïº┘ä ┘êÏÁ┘ä Ïº┘äÏ»┘üÏ╣ ┘ä┘äÏÑÏ»ÏºÏ▒Ï® Ï¿┘åÏ¼ÏºÏ¡ ┘ä┘èÏ¬┘à ┘àÏ▒ÏºÏ¼Ï╣Ï¬┘ç.');\n                setIsUploadModalOpen(false);\n                setUploadData({ amount: '', payment_method: 'Bank Transfer', notes: '' });\n                fetchPayments(); // Refresh list\n            } else {\n                alert('Ï¡Ï»Ï½ Ï«ÏÀÏú ÏúÏ½┘åÏºÏí Ïº┘äÏÑÏ▒Ï│Ïº┘ä');\n            }\n        } catch (error) {\n            console.error('Submit error:', error);\n            alert('Ï«ÏÀÏú ┘ü┘è Ïº┘äÏºÏ¬ÏÁÏº┘ä');\n        } finally {\n            setIsUploading(false);\n        }\n    };\n\n    if (isLoading) {\n        return (\n            <div className=\"flex items-center justify-center h-64\">\n                <div className=\"animate-spin rounded-full h-12 w-12 border-b-2 border-sky-600\"></div>\n            </div>\n        );\n    }\n\n    const totalPaid = payments.filter(p => p.status === 'Completed' || p.status === 'paid').reduce((sum, p) => sum + (p.amount || 0), 0);\n    const totalPending = payments.filter(p => p.status === 'Pending' || p.status === 'pending').reduce((sum, p) => sum + (p.amount || 0), 0);\n    const paidCount = payments.filter(p => p.status === 'Completed' || p.status === 'paid').length;\n    const pendingCount = payments.filter(p => p.status === 'Pending' || p.status === 'pending').length;\n\n    return (\n        <div className=\"animate-fade-in space-y-8 text-right\" dir=\"rtl\">\n            <div className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4\">\n                <div>\n                    <h1 className=\"text-3xl font-extrabold tracking-tight text-slate-900 mb-1\">\n                        Ïº┘ä┘êÏÂÏ╣┘èÏ® <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-emerald-600\">Ïº┘ä┘àÏº┘ä┘èÏ®</span>\n                    </h1>\n                    <p className=\"text-[15px] font-medium text-slate-500\">┘àÏ¬ÏºÏ¿Ï╣Ï® Ï▒Ï│┘ê┘à Ïº┘äÏº┘åÏ«Ï▒ÏºÏÀ ┘êÏº┘äÏ»┘üÏ╣ÏºÏ¬ Ïº┘äÏ│ÏºÏ¿┘éÏ®</p>\n                </div>\n                <button\n                    onClick={() => setIsUploadModalOpen(true)}\n                    className=\"flex items-center gap-2 bg-gradient-to-r from-sky-600 to-indigo-600 text-white px-5 py-2.5 rounded-xl font-black transition-all shadow-lg hover:shadow-sky-500/30 hover:scale-105\"\n                >\n                    <Upload size={20} />\n                    ÏÑÏ▒Ï│Ïº┘ä ÏÑÏ½Ï¿ÏºÏ¬ Ïº┘äÏ»┘üÏ╣\n                </button>\n            </div>\n\n            {/* Summary Cards */}\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\n                <div className=\"bg-white rounded-2xl border border-slate-200 premium-shadow p-6 relative overflow-hidden group hover:border-emerald-200 transition-colors\">\n                    <div className=\"absolute top-0 right-0 w-32 h-32 bg-emerald-50 rounded-full blur-3xl -mx-10 -my-10 opacity-50\"></div>\n                    <div className=\"flex items-center gap-3 mb-4 relative z-10\">\n                        <div className=\"p-3 rounded-xl bg-emerald-100 text-emerald-600 border border-emerald-200\">\n                            <TrendingUp size={22} />\n                        </div>\n                    </div>\n                    <h4 className=\"text-3xl font-black text-slate-800 relative z-10\" dir=\"ltr\">{totalPaid} <span className=\"text-base text-slate-400\">MAD</span></h4>\n                    <p className=\"text-sm font-bold text-slate-500 mt-1 relative z-10\">ÏÑÏ¼┘àÏº┘ä┘è Ïº┘ä┘àÏ»┘ü┘êÏ╣ÏºÏ¬</p>\n                </div>\n\n                <div className=\"bg-white rounded-2xl border border-slate-200 premium-shadow p-6 relative overflow-hidden group hover:border-amber-200 transition-colors\">\n                    <div className=\"absolute top-0 right-0 w-32 h-32 bg-amber-50 rounded-full blur-3xl -mx-10 -my-10 opacity-50\"></div>\n                    <div className=\"flex items-center gap-3 mb-4 relative z-10\">\n                        <div className=\"p-3 rounded-xl bg-amber-100 text-amber-600 border border-amber-200\">\n                            <Clock size={22} />\n                        </div>\n                    </div>\n                    <h4 className=\"text-3xl font-black text-slate-800 relative z-10\" dir=\"ltr\">{totalPending} <span className=\"text-base text-slate-400\">MAD</span></h4>\n                    <p className=\"text-sm font-bold text-slate-500 mt-1 relative z-10\">┘é┘èÏ» Ïº┘ä┘àÏ▒ÏºÏ¼Ï╣Ï®</p>\n                </div>\n\n                <div className=\"bg-white rounded-2xl border border-slate-200 premium-shadow p-6 relative\">\n                    <div className=\"flex items-center gap-3 mb-4\">\n                        <div className=\"p-3 rounded-xl bg-sky-100 text-sky-600 border border-sky-200\">\n                            <CheckCircle2 size={22} />\n                        </div>\n                    </div>\n                    <h4 className=\"text-3xl font-black text-slate-800\">{paidCount}</h4>\n                    <p className=\"text-sm font-bold text-slate-500 mt-1\">ÏºÏ┤Ï¬Ï¿Ï▒Ïº┘âÏºÏ¬ ┘àÏñ┘âÏ»Ï®</p>\n                </div>\n\n                <div className=\"bg-white rounded-2xl border border-slate-200 premium-shadow p-6 relative\">\n                    <div className=\"flex items-center gap-3 mb-4\">\n                        <div className=\"p-3 rounded-xl bg-slate-100 text-slate-600 border border-slate-200\">\n                            <AlertTriangle size={22} />\n                        </div>\n                    </div>\n                    <h4 className=\"text-3xl font-black text-slate-800\">{pendingCount}</h4>\n                    <p className=\"text-sm font-bold text-slate-500 mt-1\">┘è┘ÅÏ▒Ï¼┘ë Ïº┘äÏ¬Ï¡┘é┘é ┘à┘å┘çÏº</p>\n                </div>\n            </div>\n\n            {/* Payment Table */}\n            <div className=\"bg-white rounded-[2.5rem] border border-slate-200 premium-shadow overflow-hidden p-2\">\n                <div className=\"px-6 py-5 rounded-3xl bg-slate-50 flex items-center justify-between mb-2\">\n                    <div className=\"flex items-center gap-3\">\n                        <CreditCard size={20} className=\"text-indigo-600\" />\n                        <h3 className=\"font-extrabold text-slate-800 text-lg\">┘â┘ä Ïº┘äÏ╣┘à┘ä┘èÏºÏ¬</h3>\n                    </div>\n                    <span className=\"text-xs font-black text-slate-400 bg-white px-3 py-1.5 rounded-xl border border-slate-100\">{payments.length} Ï╣┘à┘ä┘èÏ®</span>\n                </div>\n\n                {payments.length === 0 ? (\n                    <div className=\"p-12 text-center text-slate-500 bg-slate-50/50 rounded-3xl mx-2 mb-2\">\n                        <CreditCard className=\"mx-auto mb-4 opacity-50\" size={48} />\n                        <h4 className=\"font-bold text-slate-700 mb-2\">┘äÏº Ï¬┘êÏ¼Ï» Ï╣┘à┘ä┘èÏºÏ¬</h4>\n                        <p className=\"text-sm\">┘ä┘à Ï¬┘é┘à Ï¿Ïú┘è Ï╣┘à┘ä┘èÏ® Ï»┘üÏ╣ Ï¡Ï¬┘ë Ïº┘äÏó┘å.</p>\n                    </div>\n                ) : (\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"w-full text-right\">\n                            <thead className=\"bg-transparent border-b border-slate-100\">\n                                <tr className=\"text-[11px] font-black uppercase text-slate-400\">\n                                    <th className=\"px-6 py-4\">Ï¬ÏºÏ▒┘èÏ« Ïº┘äÏ»┘üÏ╣</th>\n                                    <th className=\"px-6 py-4\">Ïº┘ä┘àÏ¿┘äÏ║</th>\n                                    <th className=\"px-6 py-4\">ÏÀÏ▒┘è┘éÏ® Ïº┘äÏ»┘üÏ╣</th>\n                                    <th className=\"px-6 py-4 text-center\">Ïº┘äÏ¡Ïº┘äÏ®</th>\n                                </tr>\n                            </thead>\n                            <tbody className=\"divide-y divide-slate-50/80\">\n                                {payments.map((payment, i) => (\n                                    <tr key={i} className=\"hover:bg-slate-50/80 transition-colors\">\n                                        <td className=\"px-6 py-4\">\n                                            <div className=\"font-bold text-slate-800\">\n                                                {payment.payment_date ? new Date(payment.payment_date).toLocaleDateString('en-GB') : 'N/A'}\n                                            </div>\n                                            {payment.notes && <div className=\"text-xs text-slate-500 mt-1 truncate max-w-[150px]\">{payment.notes}</div>}\n                                        </td>\n                                        <td className=\"px-6 py-4\">\n                                            <div className=\"font-black text-slate-900 bg-slate-50 inline-block px-3 py-1 rounded-lg border border-slate-100 shadow-sm\" dir=\"ltr\">\n                                                {payment.amount} <span className=\"text-[10px] text-slate-400\">MAD</span>\n                                            </div>\n                                        </td>\n                                        <td className=\"px-6 py-4 text-sm font-medium text-slate-600\">\n                                            {payment.payment_method === 'Cash' ? '┘å┘éÏ»Ïº┘ï (Cash)' :\n                                             payment.payment_method === 'Bank Transfer' ? 'Ï¬Ï¡┘ê┘è┘ä Ï¿┘å┘â┘è' :\n                                             payment.payment_method === 'Wafacash' ? '┘ê┘üÏº┘âÏºÏ┤' :\n                                             payment.payment_method}\n                                        </td>\n                                        <td className=\"px-6 py-4 text-center\">\n                                            <span className={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-black ${\n                                                payment.status === 'Completed' || payment.status === 'paid'\n                                                    ? 'bg-emerald-100 text-emerald-700'\n                                                    : payment.status === 'Overdue'\n                                                    ? 'bg-red-100 text-red-700'\n                                                    : 'bg-amber-100 text-amber-700'\n                                            }`}>\n                                                {payment.status === 'Completed' || payment.status === 'paid' ? <CheckCircle2 size={14} /> : \n                                                 payment.status === 'Overdue' ? <AlertTriangle size={14} /> : <Clock size={14} />}\n                                                \n                                                {payment.status === 'Completed' || payment.status === 'paid' ? 'Ï¬┘à Ïº┘äÏ»┘üÏ╣' : \n                                                 payment.status === 'Overdue' ? '┘àÏ¬ÏúÏ«Ï▒' : '┘é┘èÏ» Ïº┘ä┘àÏ▒ÏºÏ¼Ï╣Ï®'}\n                                            </span>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                )}\n            </div>\n\n            {/* Upload Receipt Modal */}\n            {isUploadModalOpen && (\n                <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-200\">\n                    <div className=\"bg-white rounded-[2.5rem] p-6 sm:p-8 w-full max-w-md shadow-2xl relative border border-slate-100\">\n                        <button \n                            onClick={() => setIsUploadModalOpen(false)}\n                            className=\"absolute top-6 left-6 text-slate-400 hover:text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-full p-2 transition-colors\"\n                        >\n                            <X size={20} />\n                        </button>\n\n                        <h2 className=\"text-2xl font-black text-slate-800 mb-2 flex items-center gap-2\">\n                            <Camera className=\"text-sky-600\" /> ÏÑÏ▒Ï│Ïº┘ä ÏÑÏ½Ï¿ÏºÏ¬ Ï»┘üÏ╣\n                        </h2>\n                        <p className=\"text-slate-500 text-sm font-medium mb-6 leading-relaxed\">┘é┘à Ï¿Ï¬Ï╣Ï¿ÏªÏ® ┘àÏ╣┘ä┘ê┘àÏºÏ¬ Ïº┘äÏ»┘üÏ╣ ┘êÏÑÏ▒┘üÏº┘é ÏÁ┘êÏ▒Ï® Ïº┘äÏ¬┘êÏÁ┘è┘ä Ïº┘äÏ¿┘å┘â┘è Ïú┘ê ┘ê┘üÏº┘âÏºÏ┤.</p>\n\n                        <form onSubmit={handleUploadSubmit} className=\"space-y-5\">\n                            <div>\n                                <label className=\"block text-sm font-bold text-slate-700 mb-1\">Ïº┘ä┘àÏ¿┘äÏ║ Ïº┘ä┘àÏº┘ä┘è (Ï»Ï▒┘ç┘à)</label>\n                                <div className=\"relative\">\n                                    <input\n                                        type=\"number\"\n                                        min=\"0\"\n                                        required\n                                        value={uploadData.amount}\n                                        onChange={(e) => setUploadData({...uploadData, amount: e.target.value})}\n                                        className=\"w-full pl-12 pr-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-sky-500 bg-slate-50 focus:bg-white transition-colors text-xl font-black\"\n                                        dir=\"ltr\"\n                                    />\n                                    <span className=\"absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold\">MAD</span>\n                                </div>\n                            </div>\n\n                            <div>\n                                <label className=\"block text-sm font-bold text-slate-700 mb-1\">ÏÀÏ▒┘è┘éÏ® Ïº┘äÏ»┘üÏ╣</label>\n                                <select\n                                    className=\"w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-sky-500 bg-slate-50 focus:bg-white font-bold text-slate-700\"\n                                    value={uploadData.payment_method}\n                                    onChange={(e) => setUploadData({...uploadData, payment_method: e.target.value})}\n                                >\n                                    <option value=\"Bank Transfer\">Ï¬Ï¡┘ê┘è┘ä Ï¿┘å┘â┘è (Virement)</option>\n                                    <option value=\"Wafacash\">┘ê┘âÏº┘äÏ® Wafacash</option>\n                                    <option value=\"Cash\">┘å┘éÏ»Ïº┘ï ┘ü┘è Ïº┘äÏú┘âÏºÏ»┘è┘à┘èÏ®</option>\n                                </select>\n                            </div>\n\n                            {/* Simulated Upload Box */}\n                            <div>\n                                <label className=\"block text-sm font-bold text-slate-700 mb-1\">ÏÁ┘êÏ▒Ï® Ïº┘ä┘êÏÁ┘ä (ÏºÏ«Ï¬┘èÏºÏ▒┘è Ï¡Ïº┘ä┘èÏº┘ï)</label>\n                                <div className=\"border-2 border-dashed border-slate-200 rounded-2xl p-6 text-center bg-slate-50 hover:bg-sky-50 hover:border-sky-300 transition-colors cursor-pointer group\">\n                                    <Camera className=\"mx-auto text-slate-400 group-hover:text-sky-500 mb-2 transition-colors\" size={28} />\n                                    <span className=\"text-sm font-bold text-slate-600 group-hover:text-sky-700\">ÏºÏÂÏ║ÏÀ ┘äÏº┘äÏ¬┘éÏºÏÀ Ïú┘ê ÏºÏ«Ï¬┘èÏºÏ▒ ÏÁ┘êÏ▒Ï®</span>\n                                    <p className=\"text-[10px] text-slate-400 mt-1\">┘è┘ÅÏ»Ï╣┘à ÏÁ┘êÏ▒ PNG ┘ê JPG (┘à┘èÏ▓Ï® Ï¬Ï¼Ï▒┘èÏ¿┘èÏ®)</p>\n                                </div>\n                            </div>\n\n                            <div>\n                                <label className=\"block text-sm font-bold text-slate-700 mb-1\">┘à┘äÏºÏ¡Ï©Ï® (Ï▒┘é┘à Ïº┘äÏ¡┘êÏº┘äÏ® ┘àÏ½┘äÏº┘ï)</label>\n                                <input\n                                    type=\"text\"\n                                    value={uploadData.notes}\n                                    onChange={(e) => setUploadData({...uploadData, notes: e.target.value})}\n                                    className=\"w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-sky-500 bg-slate-50 focus:bg-white\"\n                                    placeholder=\"ÏºÏ«Ï¬┘èÏºÏ▒┘è...\"\n                                />\n                            </div>\n\n                            <button\n                                type=\"submit\"\n                                disabled={isUploading}\n                                className=\"w-full py-3.5 rounded-xl font-black bg-gradient-to-r from-sky-600 to-indigo-600 text-white flex items-center justify-center gap-2 hover:shadow-lg hover:shadow-sky-500/30 transition-all disabled:opacity-50 disabled:cursor-not-allowed text-lg\"\n                            >\n                                {isUploading ? 'Ï¼ÏºÏ▒┘è Ïº┘äÏÑÏ▒Ï│Ïº┘ä...' : (\n                                    <>\n                                        <Send size={20} /> Ï¬Ïú┘â┘èÏ» ┘êÏÑÏ▒Ï│Ïº┘ä\n                                    </>\n                                )}\n                            </button>\n                        </form>\n                    </div>\n                </div>\n            )}\n        </div>\n    );\n};\n\nexport default ParentPayments;\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\tailwind.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\hp\\Desktop\\python_learning\\academy-app\\vite.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
