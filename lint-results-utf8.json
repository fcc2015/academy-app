7,"endColumn":15},{"ruleId":"no-unused-vars","severity":2,"message":"'e' is defined but never used.","line":232,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":232,"endColumn":15},{"ruleId":"no-empty","severity":2,"message":"Empty block statement.","line":232,"column":17,"nodeType":"BlockStatement","messageId":"unexpected","endLine":232,"endColumn":19,"suggestions":[{"messageId":"suggestComment","data":{"type":"block"},"fix":{"range":[7368,7368],"text":" /* empty */ "},"desc":"Add comment inside empty block statement."}]}],"suppressedMessages":[],"errorCount":13,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useRef, useCallback } from 'react';\nimport { API_URL } from '../../config';\n\nexport default function ChatManagement() {\n  const myUserId = localStorage.getItem('user_id') || '00000000-0000-0000-0000-000000000000';\n  const myRole = localStorage.getItem('role') || 'admin';\n  const myName = localStorage.getItem('user_name') || 'Admin';\n  const [groups, setGroups] = useState([]);\n  const [activeGroup, setActiveGroup] = useState(null);\n  const [messages, setMessages] = useState([]);\n  const [members, setMembers] = useState([]);\n  const [typingUsers, setTypingUsers] = useState([]);\n  const [allCoaches, setAllCoaches] = useState([]);\n  const [inputMsg, setInputMsg] = useState('');\n  const [loading, setLoading] = useState(false);\n  const [sendingImage, setSendingImage] = useState(false);\n  const [showMembers, setShowMembers] = useState(false);\n  const [showMuteModal, setShowMuteModal] = useState(null);\n  const [showBanModal, setShowBanModal] = useState(null);\n  const [muteMinutes, setMuteMinutes] = useState(30);\n  const [banMinutes, setBanMinutes] = useState(60);\n  const [error, setError] = useState('');\n  const [pollInterval, setPollInterval] = useState(null);\n  const messagesEndRef = useRef(null);\n  const typingTimeout = useRef(null);\n  const fileInputRef = useRef(null);\n  const isAdmin = myRole === 'admin';\n  const isCoach = myRole === 'coach';\n  const canModerate = isAdmin || isCoach;\n\n  useEffect(() => {\n    fetchGroups();\n    if (isAdmin) fetchAllCoaches();\n  }, []);\n\n  // Poll messages & typing when group selected\n  useEffect(() => {\n    if (!activeGroup) return;\n    fetchMessages();\n    fetchMembers();\n    const interval = setInterval(() => {\n      fetchMessages(true);\n      fetchTyping();\n    }, 2000);\n    setPollInterval(interval);\n    return () => clearInterval(interval);\n  }, [activeGroup]);\n\n  const scrollToBottom = () => {\n    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });\n  };\n\n  useEffect(() => { scrollToBottom(); }, [messages]);\n\n  async function fetchGroups() {\n    try {\n      let targetUserId = myUserId;\n      let targetRole = myRole;\n\n      if (myRole === 'parent') {\n        const playersRes = await fetch(`${API_URL}/players/`);\n        if (playersRes.ok) {\n            const players = await playersRes.json();\n            let child = players.find(p => p.user_id === myUserId || p.parent_id === myUserId);\n            if (!child && players.length > 0) child = players[0];\n            if (child) {\n                targetUserId = child.user_id;\n                targetRole = 'player';\n            }\n        }\n      }\n\n      const res = await fetch(`${API_URL}/chat/groups?user_id=${targetUserId}&role=${targetRole}`);\n      if (res.ok) setGroups(await res.json());\n    } catch (e) { console.error(e); }\n  }\n\n  async function fetchAllCoaches() {\n    try {\n      const res = await fetch(`${API_URL}/coaches/`);\n      if (res.ok) setAllCoaches(await res.json());\n    } catch (e) { console.error(e); }\n  }\n\n  async function addCoachToGroup(coach) {\n    if (!isAdmin || !activeGroup) return;\n    try {\n      const res = await fetch(`${API_URL}/chat/groups/${activeGroup.id}/add_member`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({\n          user_id: coach.user_id,\n          user_name: coach.full_name,\n          user_role: 'coach'\n        })\n      });\n      if (!res.ok) throw new Error('Failed to add coach');\n      fetchMembers();\n      setError('Ï¬┘àÏ¬ ÏÑÏÂÏº┘üÏ® Ïº┘ä┘àÏ»Ï▒Ï¿ Ï¿┘åÏ¼ÏºÏ¡');\n      setTimeout(() => setError(''), 3000);\n    } catch (e) {\n      setError('┘üÏ┤┘ä ÏÑÏÂÏº┘üÏ® Ïº┘ä┘àÏ»Ï▒Ï¿');\n      setTimeout(() => setError(''), 3000);\n    }\n  }\n\n  async function fetchMessages(silent = false) {\n    if (!activeGroup) return;\n    if (!silent) setLoading(true);\n    try {\n      const res = await fetch(`${API_URL}/chat/groups/${activeGroup.id}/messages?limit=100`);\n      if (res.ok) setMessages(await res.json());\n    } catch (e) { console.error(e); }\n    finally { if (!silent) setLoading(false); }\n  }\n\n  async function fetchMembers() {\n    if (!activeGroup) return;\n    try {\n      const res = await fetch(`${API_URL}/chat/groups/${activeGroup.id}/members`);\n      if (res.ok) setMembers(await res.json());\n    } catch (e) {}\n  }\n\n  async function fetchTyping() {\n    if (!activeGroup) return;\n    try {\n      const res = await fetch(`${API_URL}/chat/groups/${activeGroup.id}/typing?exclude_user=${myUserId}`);\n      if (res.ok) setTypingUsers(await res.json());\n    } catch (e) {}\n  }\n\n  async function joinGroup(group) {\n    try {\n      await fetch(`${API_URL}/chat/groups/${group.id}/join`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({\n          group_id: group.id,\n          user_id: myUserId,\n          user_name: myName,\n          user_role: myRole,\n          is_moderator: isCoach || isAdmin\n        })\n      });\n    } catch (e) {}\n    setActiveGroup(group);\n  }\n\n  async function sendMessage() {\n    if (!inputMsg.trim() || !activeGroup) return;\n    const content = inputMsg.trim();\n    setInputMsg('');\n    updateTyping(false);\n\n    try {\n      const res = await fetch(`${API_URL}/chat/messages`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({\n          group_id: activeGroup.id,\n          sender_id: myUserId,\n          sender_name: myName,\n          sender_role: myRole,\n          content,\n          message_type: 'text'\n        })\n      });\n      if (!res.ok) {\n        const err = await res.json();\n        setError(err.detail || 'Error sending message');\n        setTimeout(() => setError(''), 3000);\n      } else {\n        fetchMessages(true);\n      }\n    } catch (e) { setError('Network error'); }\n  }\n\n  async function sendImage(file) {\n    if (!isAdmin) return;\n    setSendingImage(true);\n    const formData = new FormData();\n    formData.append('file', file);\n    formData.append('sender_role', myRole);\n\n    try {\n      const uploadRes = await fetch(`${API_URL}/chat/upload-image`, {\n        method: 'POST',\n        body: formData\n      });\n      if (!uploadRes.ok) throw new Error('Upload failed');\n      const { url } = await uploadRes.json();\n\n      await fetch(`${API_URL}/chat/messages`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({\n          group_id: activeGroup.id,\n          sender_id: myUserId,\n          sender_name: myName,\n          sender_role: myRole,\n          image_url: url,\n          message_type: 'image'\n        })\n      });\n      fetchMessages(true);\n    } catch (e) {\n      setError('Image upload failed');\n      setTimeout(() => setError(''), 3000);\n    } finally { setSendingImage(false); }\n  }\n\n  async function deleteMessage(msgId) {\n    if (!canModerate) return;\n    await fetch(`${API_URL}/chat/messages/${msgId}`, { method: 'DELETE' });\n    fetchMessages(true);\n  }\n\n  async function updateTyping(isTyping) {\n    if (!activeGroup) return;\n    try {\n      await fetch(`${API_URL}/chat/typing`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({\n          group_id: activeGroup.id,\n          user_id: myUserId,\n          user_name: myName,\n          is_typing: isTyping\n        })\n      });\n    } catch (e) {}\n  }\n\n  function handleInputChange(e) {\n    setInputMsg(e.target.value);\n    updateTyping(true);\n    clearTimeout(typingTimeout.current);\n    typingTimeout.current = setTimeout(() => updateTyping(false), 3000);\n  }\n\n  async function applyMute(type) {\n    const { group_id, user_id } = showMuteModal;\n    await fetch(`${API_URL}/chat/moderation/mute`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        group_id,\n        target_user_id: user_id,\n        mute_type: type,\n        mute_minutes: type === 'temporary' ? muteMinutes : null\n      })\n    });\n    setShowMuteModal(null);\n    fetchMembers();\n  }\n\n  async function applyBan(type) {\n    const { group_id, user_id } = showBanModal;\n    await fetch(`${API_URL}/chat/moderation/ban`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        group_id,\n        target_user_id: user_id,\n        ban_type: type,\n        ban_minutes: type === 'temporary' ? banMinutes : null\n      })\n    });\n    setShowBanModal(null);\n    fetchMembers();\n    fetchMessages(true);\n  }\n\n  const formatTime = (ts) => {\n    if (!ts) return '';\n    const d = new Date(ts);\n    return d.toLocaleTimeString('fr-MA', { hour: '2-digit', minute: '2-digit' });\n  };\n\n  const roleColor = (role) => {\n    switch(role) {\n      case 'admin': return '#a78bfa';\n      case 'coach': return '#34d399';\n      case 'player': return '#60a5fa';\n      case 'parent': return '#fbbf24';\n      default: return '#9ca3af';\n    }\n  };\n\n  const roleTag = (role) => {\n    const tags = { admin: '­ƒææ Admin', coach: '­ƒÄ¢ Coach', player: 'ÔÜ¢ Joueur', parent: '­ƒæ¿ÔÇì­ƒæª Parent' };\n    return tags[role] || role;\n  };\n\n  const groupIcon = (category) => {\n    const icons = { U8: '­ƒÑë', U10: '­ƒÑê', U12: '­ƒÑç', U14: '­ƒÅà', U16: '­ƒÑê', U18: '­ƒÅå', general: '­ƒôó' };\n    return icons[category] || '­ƒÆ¼';\n  };\n\n  return (\n    <div className=\"chat-page\">\n      {/* ÔöÇÔöÇ Sidebar ÔöÇÔöÇ */}\n      <aside className=\"chat-sidebar\">\n        <div className=\"chat-sidebar-header\">\n          <div className=\"chat-sidebar-title\">\n            <span>­ƒÆ¼</span>\n            <h2>Ïº┘äÏ¬┘êÏºÏÁ┘ä</h2>\n          </div>\n          <span className=\"chat-badge\">{groups.length}</span>\n        </div>\n\n        <div className=\"chat-groups-list\">\n          {groups.map(g => (\n            <div\n              key={g.id}\n              className={`chat-group-item ${activeGroup?.id === g.id ? 'active' : ''}`}\n              onClick={() => joinGroup(g)}\n            >\n              <div className=\"chat-group-avatar\">\n                {groupIcon(g.category)}\n              </div>\n              <div className=\"chat-group-info\">\n                <div className=\"chat-group-name\">{g.name}</div>\n                <div className=\"chat-group-desc\">{g.description || 'Groupe de discussion'}</div>\n              </div>\n              {g.type === 'group' && <span className=\"chat-group-badge\">GROUP</span>}\n            </div>\n          ))}\n        </div>\n      </aside>\n\n      {/* ÔöÇÔöÇ Main Chat Area ÔöÇÔöÇ */}\n      <main className=\"chat-main\">\n        {!activeGroup ? (\n          <div className=\"chat-empty\">\n            <div className=\"chat-empty-icon\">­ƒÆ¼</div>\n            <h3>ÏºÏ«Ï¬Ï▒ ┘àÏ¼┘à┘êÏ╣Ï® ┘ä┘äÏ¿Ï»Ïí</h3>\n            <p>ÏºÏÂÏ║ÏÀ Ï╣┘ä┘ë Ïú┘è ┘àÏ¼┘à┘êÏ╣Ï® ┘à┘å Ïº┘ä┘éÏºÏª┘àÏ® Ï╣┘ä┘ë Ïº┘ä┘èÏ│ÏºÏ▒</p>\n          </div>\n        ) : (\n          <>\n            {/* Header */}\n            <div className=\"chat-header\">\n              <div className=\"chat-header-left\">\n                <button \n                  className=\"chat-btn-back-mobile\" \n                  onClick={() => setActiveGroup(null)}\n                >\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><path d=\"m9 18 6-6-6-6\"/></svg>\n                </button>\n                <div className=\"chat-header-avatar\">{groupIcon(activeGroup.category)}</div>\n                <div>\n                  <div className=\"chat-header-name\">{activeGroup.name}</div>\n                  <div className=\"chat-header-status\">\n                    {typingUsers.length > 0\n                      ? `Ô£ì´©Å ${typingUsers.map(t => t.user_name).join(', ')} ┘è┘âÏ¬Ï¿...`\n                      : `${members.length} Ï╣ÏÂ┘ê`\n                    }\n                  </div>\n                </div>\n              </div>\n              <div className=\"chat-header-actions\">\n                {isAdmin && (\n                  <button\n                    className=\"chat-btn-members\"\n                    onClick={() => setShowMembers(!showMembers)}\n                  >\n                    ­ƒæÑ Ïº┘äÏúÏ╣ÏÂÏºÏí\n                  </button>\n                )}\n              </div>\n            </div>\n\n            {/* Error bar */}\n            {error && <div className=\"chat-error-bar\">ÔÜá´©Å {error}</div>}\n\n            {/* Messages */}\n            <div className=\"chat-messages-area\">\n              {loading ? (\n                <div className=\"chat-loading\">ÔÅ│ Ï¬Ï¡┘à┘è┘ä Ïº┘äÏ▒Ï│ÏºÏª┘ä...</div>\n              ) : messages.length === 0 ? (\n                <div className=\"chat-no-messages\">┘äÏº Ï¬┘êÏ¼Ï» Ï▒Ï│ÏºÏª┘ä Ï¿Ï╣Ï». ÏºÏ¿Ï»Ïú Ïº┘ä┘àÏ¡ÏºÏ»Ï½Ï® ­ƒæï</div>\n              ) : (\n                messages.map(msg => {\n                  const isMe = msg.sender_id === myUserId;\n                  const isSystem = msg.message_type === 'system';\n\n                  if (isSystem) return (\n                    <div key={msg.id} className=\"chat-msg-system\">\n                      {msg.content}\n                    </div>\n                  );\n\n                  return (\n                    <div key={msg.id} className={`chat-msg-wrap ${isMe ? 'me' : 'them'}`}>\n                      {!isMe && (\n                        <div className=\"chat-msg-avatar\" style={{ background: roleColor(msg.sender_role) }}>\n                          {msg.sender_name[0]?.toUpperCase()}\n                        </div>\n                      )}\n                      <div className={`chat-msg-bubble ${isMe ? 'bubble-me' : 'bubble-them'}`}>\n                        {!isMe && (\n                          <div className=\"chat-msg-sender\" style={{ color: roleColor(msg.sender_role) }}>\n                            {msg.sender_name}\n                            <span className=\"chat-msg-role\">{roleTag(msg.sender_role)}</span>\n                          </div>\n                        )}\n                        {msg.message_type === 'image' && msg.image_url ? (\n                          <img src={msg.image_url} alt=\"chat image\" className=\"chat-msg-image\" />\n                        ) : (\n                          <div className=\"chat-msg-text\">{msg.content}</div>\n                        )}\n                        <div className=\"chat-msg-meta\">\n                          <span className=\"chat-msg-time\">{formatTime(msg.created_at)}</span>\n                          {canModerate && (\n                            <button\n                              className=\"chat-msg-delete\"\n                              onClick={() => deleteMessage(msg.id)}\n                              title=\"Ï¡Ï░┘ü Ïº┘äÏ▒Ï│Ïº┘äÏ®\"\n                            >­ƒùæ´©Å</button>\n                          )}\n                        </div>\n                      </div>\n                    </div>\n                  );\n                })\n              )}\n              <div ref={messagesEndRef} />\n            </div>\n\n            {/* Input */}\n            <div className=\"chat-input-area\">\n              {isAdmin && (\n                <>\n                  <button\n                    className=\"chat-btn-image\"\n                    onClick={() => fileInputRef.current?.click()}\n                    title=\"ÏÑÏÂÏº┘üÏ® ÏÁ┘êÏ▒Ï® (Admin ┘ü┘éÏÀ)\"\n                    disabled={sendingImage}\n                  >\n                    {sendingImage ? 'ÔÅ│' : '­ƒû╝´©Å'}\n                  </button>\n                  <input\n                    type=\"file\"\n                    ref={fileInputRef}\n                    accept=\"image/*\"\n                    style={{ display: 'none' }}\n                    onChange={(e) => e.target.files[0] && sendImage(e.target.files[0])}\n                  />\n                </>\n              )}\n              <input\n                className=\"chat-input\"\n                type=\"text\"\n                placeholder=\"Ïº┘âÏ¬Ï¿ Ï▒Ï│Ïº┘äÏ®...\"\n                value={inputMsg}\n                onChange={handleInputChange}\n                onKeyDown={e => e.key === 'Enter' && sendMessage()}\n                dir=\"rtl\"\n              />\n              <button className=\"chat-btn-send\" onClick={sendMessage} disabled={!inputMsg.trim()}>\n                Ô×ñ\n              </button>\n            </div>\n          </>\n        )}\n      </main>\n\n      {/* ÔöÇÔöÇ Members Sidebar ÔöÇÔöÇ */}\n      {isAdmin && showMembers && activeGroup && (\n        <div className=\"chat-members-panel\">\n          <div className=\"chat-members-header\">\n            <h3>­ƒæÑ ÏúÏ╣ÏÂÏºÏí Ïº┘ä┘àÏ¼┘à┘êÏ╣Ï®</h3>\n            <button onClick={() => setShowMembers(false)}>Ô£ò</button>\n          </div>\n          <div className=\"chat-members-list\">\n            {isAdmin && (\n              <div className=\"chat-add-member-section\" style={{ padding: '12px', borderBottom: '1px solid rgba(255,255,255,0.05)' }}>\n                <h4 style={{ fontSize: '0.8rem', color: '#a78bfa', marginBottom: '8px' }}>+ ÏÑÏÂÏº┘üÏ® ┘àÏ»Ï▒Ï¿ ┘ä┘ä┘àÏ¼┘à┘êÏ╣Ï®</h4>\n                <select \n                  style={{ width: '100%', padding: '8px', borderRadius: '8px', background: 'rgba(255,255,255,0.05)', color: 'white', border: '1px solid rgba(139,92,246,0.3)' }}\n                  onChange={(e) => {\n                    if(e.target.value) {\n                      const coach = allCoaches.find(c => c.user_id === e.target.value);\n                      if(coach) addCoachToGroup(coach);\n                      e.target.value = '';\n                    }\n                  }}\n                >\n                  <option value=\"\">-- ÏºÏ«Ï¬Ï▒ ┘àÏ»Ï▒Ï¿Ïº┘ï --</option>\n                  {allCoaches.map(c => <option key={c.user_id} value={c.user_id}>{c.full_name}</option>)}\n                </select>\n              </div>\n            )}\n            {members.map(m => (\n              <div key={m.id} className={`chat-member-item ${m.banned ? 'banned' : ''} ${m.is_muted ? 'muted' : ''}`}>\n                <div className=\"chat-member-avatar\" style={{ background: roleColor(m.user_role) }}>\n                  {m.user_name[0]?.toUpperCase()}\n                </div>\n                <div className=\"chat-member-info\">\n                  <div className=\"chat-member-name\">\n                    {m.user_name}\n                    {m.is_moderator && <span className=\"badge-mod\">Mod</span>}\n                    {m.banned && <span className=\"badge-ban\">┘àÏ¡Ï©┘êÏ▒</span>}\n                    {m.is_muted && <span className=\"badge-mute\">ÏÁÏº┘àÏ¬</span>}\n                  </div>\n                  <div className=\"chat-member-role\">{roleTag(m.user_role)}</div>\n                </div>\n                {canModerate && m.user_id !== myUserId && (\n                  <div className=\"chat-member-actions\">\n                    <button\n                      className=\"btn-mute-member\"\n                      onClick={() => setShowMuteModal({ group_id: activeGroup.id, user_id: m.user_id, name: m.user_name, is_muted: m.is_muted })}\n                      title={m.is_muted ? 'ÏÑ┘äÏ║ÏºÏí Ïº┘ä┘âÏ¬┘à' : '┘âÏ¬┘à'}\n                    >\n                      {m.is_muted ? '­ƒöè' : '­ƒöç'}\n                    </button>\n                    {isAdmin && (\n                      <button\n                        className=\"btn-ban-member\"\n                        onClick={() => setShowBanModal({ group_id: activeGroup.id, user_id: m.user_id, name: m.user_name, banned: m.banned })}\n                        title={m.banned ? 'Ï▒┘üÏ╣ Ïº┘äÏ¡Ï©Ï▒' : 'Ï¡Ï©Ï▒'}\n                      >\n                        {m.banned ? 'Ô£à' : '­ƒÜ½'}\n                      </button>\n                    )}\n                  </div>\n                )}\n              </div>\n            ))}\n          </div>\n        </div>\n      )}\n\n      {/* ÔöÇÔöÇ Mute Modal ÔöÇÔöÇ */}\n      {showMuteModal && (\n        <div className=\"chat-modal-overlay\" onClick={() => setShowMuteModal(null)}>\n          <div className=\"chat-modal\" onClick={e => e.stopPropagation()}>\n            <h3>­ƒöç ┘âÏ¬┘à {showMuteModal.name}</h3>\n            {showMuteModal.is_muted ? (\n              <button className=\"modal-btn-green\" onClick={() => applyMute('none')}>­ƒöè ÏÑ┘äÏ║ÏºÏí Ïº┘ä┘âÏ¬┘à</button>\n            ) : (\n              <>\n                <div className=\"modal-row\">\n                  <label>┘âÏ¬┘à ┘àÏñ┘éÏ¬ (Ï»┘éÏºÏª┘é):</label>\n                  <input type=\"number\" value={muteMinutes} onChange={e => setMuteMinutes(+e.target.value)} min={1} max={10080} />\n                  <button className=\"modal-btn-orange\" onClick={() => applyMute('temporary')}>┘âÏ¬┘à ┘àÏñ┘éÏ¬</button>\n                </div>\n                <button className=\"modal-btn-red\" onClick={() => applyMute('permanent')}>­ƒöç ┘âÏ¬┘à Ï»ÏºÏª┘à</button>\n              </>\n            )}\n            <button className=\"modal-btn-gray\" onClick={() => setShowMuteModal(null)}>ÏÑ┘äÏ║ÏºÏí</button>\n          </div>\n        </div>\n      )}\n\n      {/* ÔöÇÔöÇ Ban Modal ÔöÇÔöÇ */}\n      {showBanModal && (\n        <div className=\"chat-modal-overlay\" onClick={() => setShowBanModal(null)}>\n          <div className=\"chat-modal\" onClick={e => e.stopPropagation()}>\n            <h3>­ƒÜ½ Ï¡Ï©Ï▒ {showBanModal.name}</h3>\n            {showBanModal.banned ? (\n              <button className=\"modal-btn-green\" onClick={() => applyBan('none')}>Ô£à Ï▒┘üÏ╣ Ïº┘äÏ¡Ï©Ï▒</button>\n            ) : (\n              <>\n                <div className=\"modal-row\">\n                  <label>Ï¡Ï©Ï▒ ┘àÏñ┘éÏ¬ (Ï»┘éÏºÏª┘é):</label>\n                  <input type=\"number\" value={banMinutes} onChange={e => setBanMinutes(+e.target.value)} min={1} max={43200} />\n                  <button className=\"modal-btn-orange\" onClick={() => applyBan('temporary')}>Ï¡Ï©Ï▒ ┘àÏñ┘éÏ¬</button>\n                </div>\n                <button className=\"modal-btn-red\" onClick={() => applyBan('permanent')}>­ƒÜ½ Ï¡Ï©Ï▒ Ï»ÏºÏª┘à</button>\n              </>\n            )}\n            <button className=\"modal-btn-gray\" onClick={() => setShowBanModal(null)}>ÏÑ┘äÏ║ÏºÏí</button>\n          </div>\n        </div>\n      )}\n\n      <style>{`\n        .chat-page {\n          display: flex;\n          height: 100%;\n          min-height: calc(100vh - 80px);\n          background: #0f172a;\n          font-family: 'Segoe UI', Tahoma, sans-serif;\n          overflow: hidden;\n          position: relative;\n        }\n\n        /* ÔöÇÔöÇÔöÇ Sidebar ÔöÇÔöÇÔöÇ */\n        .chat-sidebar {\n          width: 300px;\n          min-width: 260px;\n          background: linear-gradient(180deg, #1e1b4b 0%, #1e293b 100%);\n          border-left: 1px solid rgba(139, 92, 246, 0.2);\n          display: flex;\n          flex-direction: column;\n          overflow: hidden;\n  