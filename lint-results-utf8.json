                     >\r\n                                    Ï¡Ï│┘åÏº┘ïÏî Ï¬┘à Ïº┘ä┘åÏ│Ï«\r\n                                </button>\r\n                            </div>\r\n                        ) : (\r\n                            <form onSubmit={handleSubmit} className=\"space-y-5\">\r\n                                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\r\n                                    <div>\r\n                                        <label className=\"block text-sm font-bold text-slate-700 mb-1\">Ïº┘äÏºÏ│┘à Ïº┘ä┘âÏº┘à┘ä</label>\r\n                                        <input\r\n                                            type=\"text\"\r\n                                            value={formData.full_name}\r\n                                            onChange={(e) => setFormData({...formData, full_name: e.target.value})}\r\n                                            className=\"w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-slate-50 focus:bg-white transition-colors\"\r\n                                            required\r\n                                        />\r\n                                    </div>\r\n                                    <div>\r\n                                        <label className=\"block text-sm font-bold text-slate-700 mb-1\">Ïº┘äÏ¿Ï▒┘èÏ» Ïº┘äÏÑ┘ä┘âÏ¬Ï▒┘ê┘å┘è</label>\r\n                                        <input\r\n                                            type=\"email\"\r\n                                            value={formData.email}\r\n                                            onChange={(e) => setFormData({...formData, email: e.target.value})}\r\n                                            className=\"w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-slate-50 focus:bg-white transition-colors text-left\"\r\n                                            dir=\"ltr\"\r\n                                            required\r\n                                            disabled={!!editingAdmin}\r\n                                        />\r\n                                    </div>\r\n                                </div>\r\n\r\n                                <div className=\"bg-slate-50 p-5 rounded-2xl border border-slate-200 mt-6\">\r\n                                    <h4 className=\"font-bold text-slate-800 mb-4 flex items-center gap-2\">\r\n                                        <ShieldAlert className=\"text-indigo-600\" size={18}/>\r\n                                        ┘ä┘êÏ¡Ï® Ïº┘äÏÁ┘äÏºÏ¡┘èÏºÏ¬\r\n                                    </h4>\r\n                                    <div className=\"space-y-3\">\r\n                                        <label className=\"flex items-center gap-3 cursor-pointer p-3 bg-white rounded-xl border border-slate-100 hover:border-indigo-200 transition-colors\">\r\n                                            <input\r\n                                                type=\"checkbox\"\r\n                                                name=\"can_manage_users\"\r\n                                                checked={formData.permissions.can_manage_users}\r\n                                                onChange={handleCheckboxChange}\r\n                                                className=\"w-5 h-5 text-indigo-600 rounded border-gray-300 focus:ring-indigo-500\"\r\n                                            />\r\n                                            <span className=\"font-bold text-slate-700\">ÏÑÏ»ÏºÏ▒Ï® Ïº┘ä┘äÏºÏ╣Ï¿┘è┘å (ÏÑÏÂÏº┘üÏ®Ïî Ï¬Ï╣Ï»┘è┘äÏî Ï¡Ï░┘ü)</span>\r\n                                        </label>\r\n                                        \r\n                                        <label className=\"flex items-center gap-3 cursor-pointer p-3 bg-white rounded-xl border border-slate-100 hover:border-emerald-200 transition-colors\">\r\n                                            <input\r\n                                                type=\"checkbox\"\r\n                                                name=\"can_manage_financials\"\r\n                                                checked={formData.permissions.can_manage_financials}\r\n                                                onChange={handleCheckboxChange}\r\n                                                className=\"w-5 h-5 text-emerald-600 rounded border-gray-300 focus:ring-emerald-500\"\r\n                                            />\r\n                                            <span className=\"font-bold text-slate-700\">ÏÑÏ»ÏºÏ▒Ï® Ïº┘ä┘àÏº┘ä┘èÏ® ┘êÏº┘äÏºÏ┤Ï¬Ï▒Ïº┘âÏºÏ¬</span>\r\n                                        </label>\r\n                                        \r\n                                        <label className=\"flex items-center gap-3 cursor-pointer p-3 bg-white rounded-xl border border-slate-100 hover:border-amber-200 transition-colors\">\r\n                                            <input\r\n                                                type=\"checkbox\"\r\n                                                name=\"can_manage_coaches\"\r\n                                                checked={formData.permissions.can_manage_coaches}\r\n                                                onChange={handleCheckboxChange}\r\n                                                className=\"w-5 h-5 text-amber-600 rounded border-gray-300 focus:ring-amber-500\"\r\n                                            />\r\n                                            <span className=\"font-bold text-slate-700\">ÏÑÏ»ÏºÏ▒Ï® Ïº┘ä┘àÏ»Ï▒Ï¿┘è┘å ┘êÏº┘äÏúÏÀ┘é┘à</span>\r\n                                        </label>\r\n                                    </div>\r\n                                </div>\r\n\r\n                                <div className=\"flex justify-end gap-3 pt-4\">\r\n                                    <button